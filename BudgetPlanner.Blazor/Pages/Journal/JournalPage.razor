@page "/"
@page "/journal"
@attribute [Authorize]
@implements IDisposable
@inject JournalApiService JournalSvc
@inject ProjectService ProjectSvc
@inject TransactionService TxSvc
@inject ToastService Toast
@inject BudgetState BudgetState
@inject JournalFilterState Filter
@inject SignalRService SignalR
@inject NavigationManager Nav
@using BudgetPlanner.Blazor.Components.Filter
@using BudgetPlanner.Blazor.Components.Forms
@using BudgetPlanner.Blazor.Components.Mobile
@using BudgetPlanner.Blazor.Components.Shared

<div class="desktop-journal-view">
    <div class="page-header">
        <span class="page-title">Journal — @BudgetState.ActiveBudgetName</span>
        <div class="header-actions">
            @if (_selectedIds.Any() && BudgetState.CanEdit)
            {
                <button class="btn btn-danger btn-sm" @onclick="BatchDeleteAsync">
                    <span class="material-icons" style="font-size:.9rem">delete</span> Ta bort (@_selectedIds.Count)
                </button>
            }
            <button class="btn btn-secondary btn-sm" @onclick="() => Filter.IsFilterPanelOpen = !Filter.IsFilterPanelOpen">
                <span class="material-icons" style="font-size:.9rem">filter_list</span>
                Filter @(Filter.HasActiveFilters ? "●" : "")
            </button>
            <button class="btn btn-secondary btn-sm" @onclick="ExportPdf">
                <span class="material-icons" style="font-size:.9rem">picture_as_pdf</span> PDF
            </button>
            <button class="btn btn-secondary btn-sm" @onclick="ExportExcel">
                <span class="material-icons" style="font-size:.9rem">table_view</span> Excel
            </button>
            @if (BudgetState.CanEdit)
            {
                <button class="btn btn-primary btn-sm" @onclick="() => { _editTx = null; _showForm = true; }">
                    <span class="material-icons" style="font-size:.9rem">add</span> Ny post
                </button>
            }
        </div>
    </div>

    <div class="page-content" style="display:flex;flex-direction:column;gap:14px">
        <SummaryCards Summary="_summary" />

        <div style="display:grid;grid-template-columns:@(Filter.IsFilterPanelOpen ? "300px" : "0") 1fr @(_showForm ? "360px" : "0");gap:14px;transition:grid-template-columns .2s;min-height:0">
            @if (Filter.IsFilterPanelOpen)
            {
                <div style="overflow:hidden"><JournalFilterPanel /></div>
            }

            <div class="grid-container" style="min-width:0;display:flex;flex-direction:column">
                <div class="grid-toolbar">
                    <div class="quick-filter">
                        <span class="material-icons">search</span>
                        <input placeholder="Snabbsök..." @bind="_qs" @bind:event="oninput" @bind:after="OnQs" />
                    </div>
                    <div style="display:flex;gap:4px;flex-wrap:wrap">
                        <button class="btn btn-sm @(!Filter.Query.IncludeTypes.Any() ? "btn-primary" : "btn-secondary")"
                                style="font-size:.72rem;padding:3px 8px" @onclick="Filter.ShowAllTypes">
                            Alla
                        </button>
                        @foreach (var t in Enum.GetValues<JournalEntryType>())
                        {
                            var type = t;
                            var solo = Filter.Query.IncludeTypes.Count == 1 && Filter.Query.IncludeTypes.Contains(type);
                            <button class="btn btn-sm @(solo ? "btn-primary" : "btn-secondary")"
                                    style="font-size:.72rem;padding:3px 8px"
                                    @onclick="() => Filter.SetOnlyType(type)">
                                @TypeLabel(type)
                            </button>
                        }
                    </div>
                    <div class="grid-toolbar-spacer"></div>
                    <span style="font-size:.8rem;color:var(--color-muted)">@_totalCount poster</span>
                    <select class="form-control" style="width:auto;padding:4px 8px;font-size:.8rem"
                            @bind="Filter.Query.PageSize" @bind:after="LoadAsync">
                        <option value="25">25/sida</option>
                        <option value="50">50/sida</option>
                        <option value="100">100/sida</option>
                    </select>
                </div>

                <div style="overflow:auto;flex:1">
                    @if (_loading)
                    {
                        <div style="padding:40px;text-align:center"><div class="spinner"></div></div>
                    }
                    else
                    {
                        <table style="width:100%;border-collapse:collapse" class="quickgrid">
                            <thead>
                                <tr>
                                    <th style="width:32px"><input type="checkbox" @bind="_selectAll" @bind:after="ToggleAll" /></th>
                                    <th style="cursor:pointer;width:90px" @onclick='() => Filter.SetSort("Date")'>Datum @SI("Date")</th>
                                    <th style="width:92px">Typ</th>
                                    <th style="cursor:pointer" @onclick='() => Filter.SetSort("Description")'>Beskrivning @SI("Description")</th>
                                    <th style="width:150px">Kategori / Meta</th>
                                    <th style="width:110px">Projekt</th>
                                    <th style="width:90px">Status</th>
                                    <th style="cursor:pointer;text-align:right;width:105px" @onclick='() => Filter.SetSort("Amount")'>Belopp @SI("Amount")</th>
                                    <th style="width:56px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in _entries)
                                {
                                    var e = entry;
                                    var sel = _selectedIds.Contains(e.SourceId);
                                    var expK = $"{e.EntryType}-{e.SourceId}";
                                    var exp = _expanded.Contains(expK);
                                    <tr class="@(sel ? "selected" : "")">
                                        <td @onclick:stopPropagation><input type="checkbox" checked="@sel" @onchange="() => Toggle(e.SourceId)" /></td>
                                        <td style="font-size:.8rem;color:var(--color-muted)">@e.Date.ToString("yyyy-MM-dd")</td>
                                        <td><span class="badge @TypeBadge(e.EntryType)" style="font-size:.7rem">@e.TypeLabel</span></td>
                                        <td>
                                            <span style="font-size:.875rem">@e.Description</span>
                                            @if (e.HasDetail && e.EntryType == JournalEntryType.Transaction)
                                            {
                                                <span class="badge badge-muted" style="margin-left:4px;font-size:.67rem">K</span>
                                            }
                                            @if (e.ReceiptLineCount > 0)
                                            {
                                                <span class="badge badge-muted" style="margin-left:4px;font-size:.67rem">@e.ReceiptLineCount kv.</span>
                                            }
                                            @if (e.MetaLine != null)
                                            {
                                                <div style="font-size:.75rem;color:var(--color-muted)">@e.MetaLine</div>
                                            }
                                        </td>
                                        <td style="font-size:.8rem;color:var(--color-muted)">@(e.CategoryName ?? "–")</td>
                                        <td style="font-size:.8rem;color:var(--color-muted)">@(e.ProjectName ?? "–")</td>
                                        <td>
                                            @if (e.Status != null)
                                            {
                                                <span class="badge @StatusBadge(e.Status)" style="font-size:.7rem">@e.Status</span>
                                            }
                                        </td>
                                        <td style="text-align:right">
                                            <span class="@(e.Amount >= 0 ? "amount-income" : "amount-expense")" style="font-size:.875rem;font-weight:600">@AmountStr(e)</span>
                                        </td>
                                        <td @onclick:stopPropagation style="display:flex;gap:2px">
                                            @if (e.HasDetail)
                                            {
                                                <button class="btn btn-ghost btn-icon btn-sm" @onclick="() => ToggleExpand(expK)">
                                                    <span class="material-icons" style="font-size:.9rem">@(exp ? "expand_less" : "expand_more")</span>
                                                </button>
                                            }
                                            @if (e.EntryType == JournalEntryType.ReceiptBatch)
                                            {
                                                <button class="btn btn-ghost btn-icon btn-sm" title="Öppna underlag" @onclick='() => Nav.NavigateTo($"/receipts/{e.SourceId}")'>
                                                    <span class="material-icons" style="font-size:.9rem">open_in_new</span>
                                                </button>
                                            }
                                            @if (BudgetState.CanEdit && e.EntryType == JournalEntryType.Transaction)
                                            {
                                                <button class="btn btn-ghost btn-icon btn-sm" title="Redigera" @onclick="() => EditEntry(e)">
                                                    <span class="material-icons" style="font-size:.9rem">edit</span>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                    @if (exp && e.EntryType == JournalEntryType.Transaction && e.KonteringRows.Any())
                                    {
                                        @foreach (var k in e.KonteringRows)
                                        {
                                            <tr style="background:var(--color-bg)">
                                                <td></td>
                                                <td></td>
                                                <td style="font-size:.75rem;color:var(--color-muted);padding-left:8px">↳ @k.KontoNr</td>
                                                <td style="font-size:.75rem;color:var(--color-muted)">@(k.Description ?? "")</td>
                                                <td style="font-size:.75rem;color:var(--color-muted)">@(k.CostCenter ?? "")</td>
                                                <td colspan="2"></td>
                                                <td style="text-align:right;font-size:.8rem;color:var(--color-muted)">@k.Amount.ToString("N2") kr</td>
                                                <td></td>
                                            </tr>
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 14px;border-top:1px solid var(--color-border)">
                    <span style="font-size:.8rem;color:var(--color-muted)">Sida @Filter.Query.Page av @_totalPages</span>
                    <div style="display:flex;gap:3px">
                        <button class="btn btn-secondary btn-sm" @onclick="PrevPage" disabled="@(Filter.Query.Page <= 1)">‹</button>
                        @for (var p = Math.Max(1, Filter.Query.Page - 2); p <= Math.Min(_totalPages, Filter.Query.Page + 2); p++)
                        {
                            var pg = p;
                            <button class="btn btn-sm @(pg == Filter.Query.Page ? "btn-primary" : "btn-secondary")" @onclick="() => GoPage(pg)">@pg</button>
                        }
                        <button class="btn btn-secondary btn-sm" @onclick="NextPage" disabled="@(Filter.Query.Page >= _totalPages)">›</button>
                    </div>
                </div>
            </div>

            @if (_showForm)
            {
                <div style="overflow:hidden">
                    <TransactionForm EditTransaction="_editTx" Projects="_projects"
                                     OnSaved="OnSaved" OnCancelled="() => _showForm = false" />
                </div>
            }
        </div>
    </div>
</div>

<div class="mobile-journal-view">
    <MobileJournalList />
</div>

<ConfirmDialog @ref="_confirm" Title="Ta bort" Message="Är du säker? Transaktioner kan inte återställas." />

@code {
    private List<JournalEntryDto> _entries = new();
    private List<ProjectDto> _projects = new();
    private SummaryDto? _summary;
    private HashSet<int> _selectedIds = new();
    private HashSet<string> _expanded = new();
    private TransactionDto? _editTx;
    private ConfirmDialog? _confirm;
    private string _qs = "";
    private bool _loading, _showForm, _selectAll;
    private int _totalCount, _totalPages;

    protected override async Task OnInitializedAsync()
    {
        var p = await ProjectSvc.GetAllAsync(BudgetState.ActiveBudgetId);
        _projects = p ?? new();
        Filter.FilterChanged += OnFilterChanged;
        BudgetState.StateChanged += OnStateChanged;
        SignalR.OnBudgetEvent += OnSR;
        await LoadAsync();
    }

    private async void OnFilterChanged() { await LoadAsync(); await InvokeAsync(StateHasChanged); }
    private async void OnStateChanged() { await LoadAsync(); await InvokeAsync(StateHasChanged); }

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var r = await JournalSvc.GetPagedAsync(BudgetState.ActiveBudgetId, Filter.Query);
            if (r.HasValue)
            {
                _entries = r.Value.Result.Items;
                _totalCount = r.Value.Result.TotalCount;
                _totalPages = r.Value.Result.TotalPages;
                _summary = r.Value.Summary;
            }
        }
        finally { _loading = false; }
    }

    private async Task OnSR(State.BudgetHubEvent e)
    {
        if (e.BudgetId != BudgetState.ActiveBudgetId) return;
        await LoadAsync(); await InvokeAsync(StateHasChanged);
    }

    private async Task OnSaved(TransactionDto _) { await LoadAsync(); _showForm = false; }

    private void EditEntry(JournalEntryDto e)
    {
        _editTx = new TransactionDto
        {
            Id = e.SourceId,
            StartDate = e.Date,
            EndDate = e.EndDate,
            NetAmount = e.Amount,
            Description = e.Description,
            CategoryName = e.CategoryName ?? "",
            ProjectName = e.ProjectName
        };
        _showForm = true;
    }

    private void Toggle(int id) { if (!_selectedIds.Remove(id)) _selectedIds.Add(id); _selectAll = _selectedIds.Count == _entries.Count; }
    private void ToggleAll() { _selectedIds.Clear(); if (_selectAll) foreach (var e in _entries) _selectedIds.Add(e.SourceId); }
    private void ToggleExpand(string k) { if (!_expanded.Remove(k)) _expanded.Add(k); }

    private async Task BatchDeleteAsync()
    {
        if (_confirm == null || !await _confirm.ShowAsync()) return;
        var ids = _entries.Where(e => e.EntryType == JournalEntryType.Transaction && _selectedIds.Contains(e.SourceId)).Select(e => e.SourceId).ToList();
        if (ids.Any()) await TxSvc.BatchDeleteAsync(BudgetState.ActiveBudgetId, ids);
        _selectedIds.Clear(); _selectAll = false;
        Toast.Success("Valda transaktioner borttagna.");
        await LoadAsync();
    }

    private async Task PrevPage() { Filter.SetPage(Filter.Query.Page - 1); await LoadAsync(); }
    private async Task NextPage() { Filter.SetPage(Filter.Query.Page + 1); await LoadAsync(); }
    private async Task GoPage(int p) { Filter.SetPage(p); await LoadAsync(); }
    private string SI(string c) => Filter.Query.SortBy != c ? "" : Filter.Query.SortDir == "asc" ? " ▲" : " ▼";
    private void OnQs() => Filter.Update(q => { q.FilterByDescription = !string.IsNullOrWhiteSpace(_qs); q.Description = _qs; });
    private void ExportPdf() => Nav.NavigateTo(JournalSvc.GetPdfUrl(BudgetState.ActiveBudgetId, Filter.Query), forceLoad: true);
    private void ExportExcel() => Nav.NavigateTo(JournalSvc.GetExcelUrl(BudgetState.ActiveBudgetId, Filter.Query), forceLoad: true);

    private static string TypeLabel(JournalEntryType t) => t switch { JournalEntryType.Transaction => "Transakt.", JournalEntryType.Milersattning => "Milersättn.", JournalEntryType.Vab => "VAB", JournalEntryType.ReceiptBatch => "Kvitto", _ => t.ToString() };
    private static string TypeBadge(JournalEntryType t) => t switch { JournalEntryType.Transaction => "badge-primary", JournalEntryType.Milersattning => "badge-income", JournalEntryType.Vab => "badge-income", _ => "badge" };
    private static string StatusBadge(string s) => s switch { "Godkänd" => "badge-income", "Avslagen" => "badge-expense", "Utbetald" => "badge-primary", "Inskickad" => "badge", _ => "badge-muted" };
    private static string AmountStr(JournalEntryDto e) => e.EntryType == JournalEntryType.ReceiptBatch ? $"{e.Amount:N0} kr" : (e.Amount >= 0 ? "+" : "") + $"{e.Amount:N0} kr";

    public void Dispose()
    {
        Filter.FilterChanged -= OnFilterChanged;
        BudgetState.StateChanged -= OnStateChanged;
        SignalR.OnBudgetEvent -= OnSR;
    }
}