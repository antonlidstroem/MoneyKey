@page "/receipts"
@attribute [Authorize]
@inject ReceiptApiService ReceiptSvc
@inject ToastService Toast
@inject BudgetState BudgetState
@inject NavigationManager Nav

<div class="page-header">
    <span class="page-title">Kvittounderlag</span>
    <div class="header-actions">
        @if (BudgetState.CanEdit)
        {
            <button class="btn btn-primary btn-sm" @onclick="() => _showCreate = true">
                <span class="material-icons" style="font-size:.9rem">add</span> Nytt underlag
            </button>
        }
    </div>
</div>

<div class="page-content">
    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px">
        <button class="btn btn-sm @(_sf == null ? "btn-primary" : "btn-secondary")" @onclick="() => SetFilter(null)">Alla</button>
        @foreach (var s in Enum.GetValues<ReceiptBatchStatus>())
        {
            var status = s;
            <button class="btn btn-sm @(_sf == status ? "btn-primary" : "btn-secondary")" @onclick="() => SetFilter(status)">@Sw(status)</button>
        }
    </div>
    <div class="grid-container">
        <table style="width:100%;border-collapse:collapse" class="quickgrid">
            <thead>
                <tr>
                    <th>Etikett</th>
                    <th>Kategori</th>
                    <th>Projekt</th>
                    <th style="text-align:right">Kvitton</th>
                    <th style="text-align:right">Totalt</th>
                    <th>Status</th>
                    <th>Skapad av</th>
                    <th>Datum</th>
                    <th style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @if (_loading)
                {
                    <tr><td colspan="9" style="text-align:center;padding:32px"><div class="spinner"></div></td></tr>
                }
                else if (!_batches.Any())
                {
                    <tr><td colspan="9" style="text-align:center;padding:32px;color:var(--color-muted)">Inga kvittounderlag ännu.</td></tr>
                }
                else
                {
                    @foreach (var b in _batches)
                    {
                        var batch = b;
                        <tr style="cursor:pointer" @onclick='() => Nav.NavigateTo($"/receipts/{batch.Id}")'>
                            <td style="font-weight:500">@batch.Label</td>
                            <td style="font-size:.85rem">
                                @if (batch.BatchCategoryIcon != null)
                                {
                                    <span class="material-icons" style="font-size:1rem;vertical-align:middle;margin-right:3px">@batch.BatchCategoryIcon</span>
                                }
                                @batch.BatchCategoryName
                            </td>
                            <td style="font-size:.85rem;color:var(--color-muted)">@(batch.ProjectName ?? "–")</td>
                            <td style="text-align:right;font-size:.85rem;color:var(--color-muted)">@batch.LineCount st</td>
                            <td style="text-align:right;font-weight:600">@batch.TotalAmount.ToString("N2") kr</td>
                            <td><span class="badge @SBadge(batch.Status)" style="font-size:.72rem">@batch.StatusLabel</span></td>
                            <td style="font-size:.8rem;color:var(--color-muted)">@(batch.CreatedByEmail ?? "–")</td>
                            <td style="font-size:.8rem;color:var(--color-muted)">@batch.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td @onclick:stopPropagation>
                                <button class="btn btn-ghost btn-icon btn-sm" @onclick='() => Nav.NavigateTo($"/receipts/{batch.Id}")'>
                                    <span class="material-icons" style="font-size:.9rem">open_in_new</span>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* (Create modal and code block remains the same as your source) *@

@code {
    private List<ReceiptBatchDto> _batches = new();
    private List<ReceiptBatchCategoryDto> _cats = new();
    private ReceiptBatchStatus? _sf;
    private string _newLabel = "";
    private int _newCatId;
    private bool _loading = true, _showCreate, _creating;

    protected override async Task OnInitializedAsync()
    {
        var c = await ReceiptSvc.GetCategoriesAsync(BudgetState.ActiveBudgetId);
        _cats = c ?? new();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var r = await ReceiptSvc.GetAllAsync(BudgetState.ActiveBudgetId);
        _batches = (r?.Items ?? new()).Where(b => _sf == null || b.Status == _sf).ToList();
        _loading = false;
    }

    private async Task SetFilter(ReceiptBatchStatus? s) { _sf = s; await LoadAsync(); }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newLabel) || _newCatId == 0) return;
        _creating = true;
        try
        {
            var b = await ReceiptSvc.CreateAsync(BudgetState.ActiveBudgetId, new CreateReceiptBatchDto(_newLabel, _newCatId, null));
            if (b != null) { Toast.Success("Underlag skapat."); _showCreate = false; Nav.NavigateTo($"/receipts/{b.Id}"); }
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _creating = false; }
    }

    private static string SBadge(ReceiptBatchStatus s) => s switch { ReceiptBatchStatus.Draft => "badge-muted", ReceiptBatchStatus.Submitted => "badge", ReceiptBatchStatus.Approved => "badge-income", ReceiptBatchStatus.Rejected => "badge-expense", ReceiptBatchStatus.Reimbursed => "badge-primary", _ => "badge-muted" };
    private static string Sw(ReceiptBatchStatus s) => s switch { ReceiptBatchStatus.Draft => "Utkast", ReceiptBatchStatus.Submitted => "Inskickad", ReceiptBatchStatus.Approved => "Godkänd", ReceiptBatchStatus.Rejected => "Avslagen", ReceiptBatchStatus.Reimbursed => "Utbetald", _ => s.ToString() };
}