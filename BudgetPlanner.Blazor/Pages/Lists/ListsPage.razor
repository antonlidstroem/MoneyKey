@page "/lists"
@attribute [Authorize]
@implements IDisposable
@inject TaskListApiService ListSvc
@inject ToastService Toast
@inject BudgetState BudgetState
@inject SignalRService SignalR
@inject NavigationManager Nav

<!-- ══════════════════════════════════════════════════════════════════════════
     DESKTOP
     ══════════════════════════════════════════════════════════════════════════ -->
<div class="desktop-page-wrapper">
    <div class="page-header">
        <span class="page-title">Listor</span>
        <div class="header-actions">
            @if (BudgetState.CanEdit)
            {
                <button class="btn btn-primary btn-sm" @onclick='() => _newOpen = true'>
                    <span class="material-icons" style="font-size:.9rem">add</span> Ny lista
                </button>
            }
        </div>
    </div>

    <div class="page-content" style="overflow-y:auto;padding:0">
        @ListsContent()
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════
     MOBILE
     ══════════════════════════════════════════════════════════════════════════ -->
<div class="mobile-page-shell">
    <div class="mobile-topbar">
        <span class="mobile-title">Listor</span>
    </div>

    <div class="mobile-page-scroll" style="padding:0">
        @ListsContent()
    </div>

    @if (BudgetState.CanEdit)
    {
        <button class="mobile-fab" @onclick='() => _newOpen = true'>
            <span class="material-icons">add</span>
        </button>
    }
</div>

<!-- ══════════════════════════════════════════════════════════════════════════
     NEW LIST SHEET
     ══════════════════════════════════════════════════════════════════════════ -->
@if (_newOpen)
{
    <div class="sheet-overlay" @onclick='() => _newOpen = false'>
        <div class="sheet-container" @onclick:stopPropagation
             style="max-height:90%;overflow-y:auto">
            <div class="sheet-handle-bar"></div>
            <div style="padding:12px 16px;font-weight:600;font-size:.95rem">
                Ny lista
            </div>
            <div style="padding:0 16px 24px">

                <!-- Live preview card -->
                <div class="list-card" style="--list-color:@_newColor;margin-bottom:16px">
                    <span class="list-card-emoji">@_newEmoji</span>
                    <div class="list-card-title">
                        @(string.IsNullOrWhiteSpace(_newTitle) ? "Namnlös lista" : _newTitle)
                    </div>
                    <div class="list-card-meta">@TypeLabel(_newType) · 0 uppgifter</div>
                </div>

                <div class="form-group" style="margin-bottom:14px">
                    <label class="form-label">Namn</label>
                    <input class="form-control" @bind="_newTitle"
                           @bind:event="oninput" placeholder="Min lista..." />
                </div>

                <div class="form-group" style="margin-bottom:14px">
                    <label class="form-label">Typ</label>
                    <div style="display:flex;gap:8px">
                        @foreach (var lt in Enum.GetValues<TaskListType>())
                        {
                            var t = lt;
                            <button class="btn btn-sm @(_newType == t ? "btn-primary" : "btn-secondary")"
                                    @onclick="() => _newType = t">
                                @TypeLabel(t)
                            </button>
                        }
                    </div>
                </div>

                <div class="form-group" style="margin-bottom:14px">
                    <label class="form-label">Emoji</label>
                    <div class="new-list-emoji-row">
                        @foreach (var em in Emojis)
                        {
                            var emoji = em;
                            <button class="emoji-btn @(_newEmoji == emoji ? "selected" : "")"
                                    @onclick="() => _newEmoji = emoji">@emoji</button>
                        }
                    </div>
                </div>

                <div class="form-group" style="margin-bottom:20px">
                    <label class="form-label">Färg</label>
                    <div class="new-list-color-row">
                        @foreach (var c in Colors)
                        {
                            var col = c;
                            <button class="color-swatch @(_newColor == col ? "selected" : "")"
                                    style="background:@col"
                                    @onclick="() => _newColor = col">
                            </button>
                        }
                    </div>
                </div>

                <div style="display:flex;gap:10px">
                    <button class="btn btn-secondary" @onclick='() => _newOpen = false'>
                        Avbryt
                    </button>
                    <button class="btn btn-primary" @onclick="CreateAsync"
                            disabled="@(string.IsNullOrWhiteSpace(_newTitle) || _saving)">
                        @if (_saving)
                        {
                            <span class="spinner" style="width:14px;height:14px;border-width:2px"></span>
                        }
                        Skapa lista
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<TaskListDto> _lists   = new();
    private bool              _loading = true;
    private bool              _newOpen;
    private bool              _saving;

    private string       _newTitle = "";
    private TaskListType _newType  = TaskListType.ToDo;
    private string       _newEmoji = "📋";
    private string       _newColor = "#1565C0";

    private static readonly string[] Emojis =
    {
        "📋","✅","🛒","📝","🎯","💡","🏠","💼","🎉","📚","🏋️","🌱"
    };
    private static readonly string[] Colors =
    {
        "#1565C0","#2E7D32","#C62828","#F57F17","#6A1B9A",
        "#00838F","#37474F","#AD1457","#4E342E","#1B5E20"
    };

    // ── Lifecycle ──────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        BudgetState.StateChanged += OnStateChanged;
        SignalR.OnBudgetEvent    += OnSignalR;
        await LoadAsync();
    }

    public void Dispose()
    {
        BudgetState.StateChanged -= OnStateChanged;
        SignalR.OnBudgetEvent    -= OnSignalR;
    }

    private void OnStateChanged() => InvokeAsync(async () =>
    {
        await LoadAsync(); StateHasChanged();
    });

    private async Task OnSignalR(State.BudgetHubEvent e)
    {
        if (e.BudgetId != BudgetState.ActiveBudgetId) return;
        if (e.Event.StartsWith("TaskList"))
        {
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadAsync()
    {
        if (BudgetState.ActiveBudgetId <= 0) { _loading = false; return; }
        _loading = true;
        var result = await ListSvc.GetAllAsync(BudgetState.ActiveBudgetId);
        _lists   = result ?? new();
        _loading = false;
    }

    // ── Create ─────────────────────────────────────────────────────────────────

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTitle)) return;
        _saving = true;
        try
        {
            var created = await ListSvc.CreateAsync(
                BudgetState.ActiveBudgetId,
                new CreateTaskListDto(_newTitle.Trim(), _newType, _newEmoji, _newColor));

            if (created != null)
            {
                _newOpen  = false;
                _newTitle = "";
                _newType  = TaskListType.ToDo;
                _newEmoji = "📋";
                _newColor = "#1565C0";
                Nav.NavigateTo($"/lists/{created.Id}");
            }
            else
            {
                Toast.Error("Kunde inte skapa listan.");
            }
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _saving = false; }
    }

    // ── Shared content ─────────────────────────────────────────────────────────

    private RenderFragment ListsContent() =>
        @<div>
            @if (_loading)
            {
                <div style="text-align:center;padding:60px">
                    <div class="spinner"></div>
                </div>
            }
            else if (!_lists.Any())
            {
                <div style="text-align:center;padding:60px 24px;color:var(--color-muted)">
                    <span style="font-size:3rem;display:block;margin-bottom:12px">📋</span>
                    <div style="font-size:.95rem;font-weight:500;margin-bottom:6px">
                        Inga listor ännu
                    </div>
                    <div style="font-size:.85rem;margin-bottom:20px">
                        Skapa din första lista för att komma igång.
                    </div>
                    @if (BudgetState.CanEdit)
                    {
                        <button class="btn btn-primary" @onclick='() => _newOpen = true'>
                            <span class="material-icons" style="font-size:.9rem">add</span>
                            Ny lista
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="lists-grid">
                    @foreach (var list in _lists)
                    {
                        var l = list;
                        <div class="list-card"
                             style="--list-color:@l.ColorHex"
                             @onclick='() => Nav.NavigateTo($"/lists/{l.Id}")'>

                            @if (l.IsComplete && l.TotalItems > 0)
                            {
                                <span class="list-card-complete-badge">✓ Klar</span>
                            }

                            <span class="list-card-emoji">@l.Emoji</span>
                            <div class="list-card-title">@l.Title</div>
                            <div class="list-card-meta">
                                @TypeLabel(l.ListType) · @l.ProgressLabel
                            </div>

                            @if (l.TotalItems > 0)
                            {
                                <div class="list-card-progress-bar">
                                    <div class="list-card-progress-fill"
                                         style="width:@l.ProgressPercent%"></div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>;

    private static string TypeLabel(TaskListType t) => t switch
    {
        TaskListType.ToDo     => "Att göra",
        TaskListType.Shopping => "Inköpslista",
        TaskListType.Generic  => "Generisk",
        _                     => t.ToString()
    };
}
