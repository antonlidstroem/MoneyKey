@* KonteringTable.razor *@
@using BudgetPlanner.Core.DTOs

<div class="kontering-table">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
        <span style="font-size:.8rem;font-weight:600;color:var(--color-muted)">KONTERING</span>
        <button class="btn btn-ghost btn-sm" @onclick="AddRow">
            <span class="material-icons" style="font-size:.9rem">add</span> Rad
        </button>
    </div>

    @foreach (var row in Rows)
    {
        var r = row;
        <div style="display:grid;grid-template-columns:90px 80px 1fr 80px 28px;gap:4px;margin-bottom:4px;align-items:center">
            <input class="form-control" style="font-size:.8rem;padding:4px 6px" placeholder="Konto nr"
                   @bind="r.KontoNr" @bind:after="OnChanged" />
            <input class="form-control" style="font-size:.8rem;padding:4px 6px" placeholder="CC"
                   @bind="r.CostCenter" @bind:after="OnChanged" />
            <input class="form-control" style="font-size:.8rem;padding:4px 6px" placeholder="Beskrivning"
                   @bind="r.Description" @bind:after="OnChanged" />
            <input class="form-control" style="font-size:.8rem;padding:4px 6px;text-align:right"
                   type="number" step="0.01" placeholder="Belopp"
                   @bind="r.Amount" @bind:after="OnChanged" />
            <button class="btn btn-ghost btn-icon btn-sm" style="color:var(--color-expense)"
                    @onclick="() => RemoveRow(r)">
                <span class="material-icons" style="font-size:.9rem">close</span>
            </button>
        </div>
    }

    @if (Rows.Any())
    {
        var total   = Rows.Sum(r => r.Amount);
        var balance = ParentAmount - total;
        <div style="display:flex;justify-content:space-between;padding:6px 4px 0;font-size:.8rem;border-top:1px solid var(--color-border);margin-top:4px">
            <span style="color:var(--color-muted)">Summa kontering:</span>
            <span style="font-weight:600;color:@(Math.Abs(balance) < 0.01m ? "var(--color-income)" : "var(--color-expense)")">
                @total.ToString("N2") kr @(Math.Abs(balance) < 0.01m ? "✓" : $"(diff {balance:N2})")
            </span>
        </div>
    }
</div>

@code {
    [Parameter] public List<KonteringRowDto> Rows         { get; set; } = new();
    [Parameter] public decimal               ParentAmount { get; set; }
    [Parameter] public EventCallback<List<KonteringRowDto>> RowsChanged { get; set; }

    private void AddRow()
    {
        Rows.Add(new KonteringRowDto());
        OnChanged();
    }

    private void RemoveRow(KonteringRowDto r)
    {
        Rows.Remove(r);
        OnChanged();
    }

    private void OnChanged() => RowsChanged.InvokeAsync(Rows);
}
