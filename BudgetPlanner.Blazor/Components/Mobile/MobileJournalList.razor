@implements IDisposable
@inject JournalApiService JournalSvc
@inject ReceiptApiService ReceiptSvc
@inject ToastService Toast
@inject BudgetState BudgetState
@inject JournalFilterState Filter
@inject SignalRService SignalR
@inject NavigationManager Nav
@using BudgetPlanner.Blazor.Components.Shared

<div class="mobile-shell">
    <div class="mobile-topbar">
        <span class="mobile-title">@BudgetState.ActiveBudgetName</span>
        <div style="display:flex;gap:6px">
            <button class="mobile-icon-btn" @onclick="ToggleSearch">
                <span class="material-icons">search</span>
            </button>
            <button class="mobile-icon-btn @(Filter.HasActiveFilters ? "active" : "")"
                    @onclick="() => _filterOpen = true">
                <span class="material-icons">filter_list</span>
                @if (Filter.HasActiveFilters) { <span class="mobile-badge"></span> }
            </button>
        </div>
    </div>

    @if (_searchOpen)
    {
        <div class="mobile-search-bar">
            <span class="material-icons" style="font-size:1rem;color:var(--color-muted)">search</span>
            <input @ref="_searchRef" placeholder="Sök beskrivning..."
                   @bind="_searchText" @bind:event="oninput" @bind:after="OnSearch"
                   style="flex:1;border:none;outline:none;background:transparent;font-size:.875rem" />
            <button class="mobile-icon-btn" @onclick="CloseSearch">
                <span class="material-icons" style="font-size:1rem">close</span>
            </button>
        </div>
    }

    @if (_summary != null)
    {
        <div class="mobile-kpi-strip">
            <div class="mobile-kpi"><div class="mobile-kpi-label">Inkomster</div><div class="mobile-kpi-val pos">+@((int)_summary.FilteredIncome) kr</div></div>
            <div class="mobile-kpi"><div class="mobile-kpi-label">Utgifter</div><div class="mobile-kpi-val neg">@((int)_summary.FilteredExpenses) kr</div></div>
            <div class="mobile-kpi"><div class="mobile-kpi-label">Netto</div><div class="mobile-kpi-val @(_summary.FilteredTotal >= 0 ? "pos" : "neg")">@((int)_summary.FilteredTotal) kr</div></div>
            <div class="mobile-kpi"><div class="mobile-kpi-label">Poster</div><div class="mobile-kpi-val">@_totalCount st</div></div>
        </div>
    }

    <div class="mobile-chips">
        <button class="mobile-chip @(!Filter.Query.IncludeTypes.Any() ? "active" : "")"
                @onclick="Filter.ShowAllTypes">Alla</button>
        @foreach (var t in Enum.GetValues<JournalEntryType>())
        {
            var type = t;
            var solo = Filter.Query.IncludeTypes.Count == 1 && Filter.Query.IncludeTypes.Contains(type);
            <button class="mobile-chip @(solo ? "active" : "")"
                    @onclick="() => Filter.SetOnlyType(type)">
                @ShortLabel(type)
            </button>
        }
    </div>

    <div class="mobile-list">
        @if (_loading)
        {
            @for (var i = 0; i < 7; i++)
            {
                <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-bottom:.5px solid var(--color-border)">
                    <div class="skeleton" style="width:32px;height:32px;border-radius:9px;flex-shrink:0"></div>
                    <div style="flex:1">
                        <div class="skeleton" style="height:13px;width:55%;margin-bottom:6px;border-radius:4px"></div>
                        <div class="skeleton" style="height:11px;width:40%;border-radius:4px"></div>
                    </div>
                    <div class="skeleton" style="width:60px;height:13px;border-radius:4px"></div>
                </div>
            }
        }
        else if (!_entries.Any())
        {
            <div style="text-align:center;padding:48px 24px;color:var(--color-muted)">
                <span class="material-icons" style="font-size:2.5rem;display:block;margin-bottom:8px">inbox</span>
                Inga poster hittades
            </div>
        }
        else
        {
            @foreach (var entry in _entries)
            {
                var e = entry;
                <div class="mobile-row" @onclick="() => _detail = e">
                    <div class="mobile-type-dot @DotCss(e.EntryType)">@e.TypeCode</div>
                    <div class="mobile-row-mid">
                        <div class="mobile-row-desc">
                            @e.Description
                            @if (e.HasDetail && e.EntryType == JournalEntryType.Transaction)
                            {
                                <span class="mobile-k-badge">K</span>
                            }
                        </div>
                        <div class="mobile-row-meta">
                            @if (e.MetaLine != null) { @e.MetaLine }
                            else { @(e.CategoryName ?? e.TypeLabel) @if (e.ProjectName != null) { <span> · @e.ProjectName</span> } }
                        </div>
                    </div>
                    <div class="mobile-row-right">
                        <div class="mobile-row-amount @AmountCss(e)">@FormatAmount(e)</div>
                        <div class="mobile-row-date">@e.Date.ToString("d MMM")</div>
                        @if (e.Status != null) { <div class="mobile-status-dot @StatusDot(e.Status)"></div> }
                    </div>
                </div>
            }
            @if (Filter.Query.Page < _totalPages)
            {
                <div style="text-align:center;padding:16px">
                    <button class="btn btn-secondary btn-sm" @onclick="LoadMore" disabled="@_loadingMore">
                        @if (_loadingMore) { <span class="spinner" style="width:14px;height:14px;border-width:2px"></span> }
                        Ladda fler (@(_totalCount - _entries.Count) kvar)
                    </button>
                </div>
            }
        }
    </div>

    @if (BudgetState.CanEdit)
    {
        <button class="mobile-fab" @onclick="() => _addOpen = true">
            <span class="material-icons">add</span>
        </button>
    }
</div>

@* Detail bottom sheet *@
@if (_detail != null)
{
    <div class="sheet-overlay" @onclick="() => _detail = null">
        <div class="sheet-container" @onclick:stopPropagation>
            <div class="sheet-handle-bar"></div>
            <div class="sheet-head">
                <div style="display:flex;align-items:center;gap:8px">
                    <span class="mobile-type-dot @DotCss(_detail.EntryType)" style="width:24px;height:24px;font-size:.7rem">@_detail.TypeCode</span>
                    <span style="font-size:15px;font-weight:500">@_detail.Description</span>
                </div>
                <button class="mobile-icon-btn" @onclick="() => _detail = null">
                    <span class="material-icons" style="font-size:1.1rem">close</span>
                </button>
            </div>
            <div class="sheet-amount @AmountCss(_detail)">@FormatAmount(_detail)</div>
            <div class="sheet-fields">
                <div class="sheet-field"><span class="sheet-field-label">Datum</span><span class="sheet-field-val">@_detail.Date.ToString("yyyy-MM-dd")</span></div>
                <div class="sheet-field"><span class="sheet-field-label">Typ</span><span class="sheet-field-val">@_detail.TypeLabel</span></div>
                @if (_detail.CategoryName != null) { <div class="sheet-field"><span class="sheet-field-label">Kategori</span><span class="sheet-field-val">@_detail.CategoryName</span></div> }
                @if (_detail.ProjectName  != null) { <div class="sheet-field"><span class="sheet-field-label">Projekt</span><span class="sheet-field-val">@_detail.ProjectName</span></div> }
                @if (_detail.MetaLine     != null) { <div class="sheet-field"><span class="sheet-field-label">Detalj</span><span class="sheet-field-val">@_detail.MetaLine</span></div> }
                @if (_detail.Status       != null) { <div class="sheet-field"><span class="sheet-field-label">Status</span><span class="sheet-field-val">@_detail.Status</span></div> }
                @if (_detail.ReferenceCode != null)
                {
                    <div class="sheet-field">
                        <span class="sheet-field-label">Referens</span>
                        <span class="sheet-field-val" style="font-family:monospace;font-weight:700;color:var(--color-primary)">@_detail.ReferenceCode</span>
                    </div>
                }
                @if (_detail.CreatedByEmail != null) { <div class="sheet-field"><span class="sheet-field-label">Skapad av</span><span class="sheet-field-val">@_detail.CreatedByEmail</span></div> }
            </div>
            @if (_detail.KonteringRows.Any())
            {
                <div style="padding:0 16px 8px">
                    <div style="font-size:.72rem;font-weight:600;color:var(--color-muted);margin-bottom:6px;text-transform:uppercase">Kontering</div>
                    <div style="background:var(--color-surface-alt);border-radius:8px;overflow:hidden">
                        @foreach (var k in _detail.KonteringRows)
                        {
                            <div style="display:flex;justify-content:space-between;padding:7px 10px;border-bottom:.5px solid var(--color-border);font-size:.8rem">
                                <span style="color:var(--color-muted)">@k.KontoNr @(k.CostCenter != null ? $"· {k.CostCenter}" : "")</span>
                                <span style="font-weight:500">@k.Amount.ToString("N2") kr</span>
                            </div>
                        }
                    </div>
                </div>
            }
            <div class="sheet-actions">
                @if (_detail.EntryType == JournalEntryType.ReceiptBatch)
                {
                    <button class="btn btn-primary" @onclick="() => { var id = _detail?.SourceId; _detail = null; Nav.NavigateTo($"/receipts/{id}"); }">
                        <span class="material-icons" style="font-size:.9rem">open_in_new</span> Öppna underlag
                    </button>
                }
            </div>
        </div>
    </div>
}

@* Add sheet *@
@if (_addOpen)
{
    <div class="sheet-overlay" @onclick="() => _addOpen = false">
        <div class="sheet-container" @onclick:stopPropagation>
            <div class="sheet-handle-bar"></div>
            <div class="sheet-head">
                <span style="font-size:15px;font-weight:500">Ny post</span>
                <button class="mobile-icon-btn" @onclick="() => _addOpen = false">
                    <span class="material-icons" style="font-size:1.1rem">close</span>
                </button>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:16px">
                @foreach (var (label, icon, url) in new[] {
                    ("Transaktion", "swap_horiz", "/journal?add=1"),
                    ("Milersättning", "directions_car", "/milersattning?add=1"),
                    ("VAB", "child_care", "/vab?add=1"),
                    ("Kvittounderlag", "receipt", "/receipts?add=1")
                })
                {
                    var navUrl = url;
                    <button class="mobile-add-type-btn" @onclick="() => { _addOpen = false; Nav.NavigateTo(navUrl); }">
                        <span class="material-icons" style="font-size:1.4rem;display:block;margin-bottom:4px">@icon</span>
                        <span style="font-size:.8rem">@label</span>
                    </button>
                }
            </div>
        </div>
    </div>
}

@* Filter sheet *@
@if (_filterOpen)
{
    <div class="sheet-overlay" @onclick="() => _filterOpen = false">
        <div class="sheet-container" style="max-height:85%" @onclick:stopPropagation>
            <div class="sheet-handle-bar"></div>
            <div class="sheet-head">
                <span style="font-size:15px;font-weight:500">Filter</span>
                <div style="display:flex;gap:8px">
                    <button class="btn btn-ghost btn-sm" @onclick="() => { Filter.ResetFilters(); _filterOpen = false; }">Rensa</button>
                    <button class="mobile-icon-btn" @onclick="() => _filterOpen = false">
                        <span class="material-icons" style="font-size:1.1rem">close</span>
                    </button>
                </div>
            </div>
            <div style="overflow-y:auto;padding:8px 16px 16px">
                <div style="font-size:.75rem;font-weight:600;color:var(--color-muted);margin:8px 0 6px;text-transform:uppercase">Från datum</div>
                <input type="date" class="form-control" style="margin-bottom:10px"
                       value="@Filter.Query.StartDate?.ToString("yyyy-MM-dd")"
                       @onchange="e => { Filter.Query.FilterByStartDate = true; Filter.Query.StartDate = e.Value?.ToString() is { Length: > 0 } s ? DateTime.Parse(s) : null; }" />
                <div style="font-size:.75rem;font-weight:600;color:var(--color-muted);margin:8px 0 6px;text-transform:uppercase">Till datum</div>
                <input type="date" class="form-control" style="margin-bottom:10px"
                       value="@Filter.Query.EndDate?.ToString("yyyy-MM-dd")"
                       @onchange="e => { Filter.Query.FilterByEndDate = true; Filter.Query.EndDate = e.Value?.ToString() is { Length: > 0 } s ? DateTime.Parse(s) : null; }" />
                <div style="font-size:.75rem;font-weight:600;color:var(--color-muted);margin:8px 0 6px;text-transform:uppercase">Fritext</div>
                <input class="form-control" placeholder="Sök i beskrivning..." style="margin-bottom:12px"
                       @bind="Filter.Query.Description"
                       @bind:after="() => Filter.Query.FilterByDescription = !string.IsNullOrWhiteSpace(Filter.Query.Description)" />
                <button class="btn btn-primary" style="width:100%;justify-content:center"
                        @onclick="() => { Filter.Update(_ => {}); _filterOpen = false; }">
                    Tillämpa filter
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<JournalEntryDto> _entries  = new();
    private SummaryDto?           _summary;
    private JournalEntryDto?      _detail;
    private ElementReference      _searchRef;
    private string _searchText = "";
    private bool _loading = true, _loadingMore, _searchOpen, _addOpen, _filterOpen;
    private int _totalCount, _totalPages;

    protected override async Task OnInitializedAsync()
    {
        Filter.FilterChanged     += OnFilterChanged;
        BudgetState.StateChanged += OnStateChanged;
        SignalR.OnBudgetEvent    += OnSignalR;
        await LoadAsync(true);
    }

    private async void OnFilterChanged() { await LoadAsync(true); await InvokeAsync(StateHasChanged); }
    private async void OnStateChanged()  { await LoadAsync(true); await InvokeAsync(StateHasChanged); }

    private async Task LoadAsync(bool reset)
    {
        if (reset) { Filter.Query.Page = 1; _entries.Clear(); }
        _loading = true;
        var r = await JournalSvc.GetPagedAsync(BudgetState.ActiveBudgetId, Filter.Query);
        if (r.HasValue)
        {
            _entries    = reset ? r.Value.Result.Items : _entries.Concat(r.Value.Result.Items).ToList();
            _totalCount = r.Value.Result.TotalCount;
            _totalPages = r.Value.Result.TotalPages;
            _summary    = r.Value.Summary;
        }
        _loading = false;
    }

    private async Task LoadMore()
    {
        _loadingMore = true; Filter.Query.Page++;
        var r = await JournalSvc.GetPagedAsync(BudgetState.ActiveBudgetId, Filter.Query);
        if (r.HasValue) _entries.AddRange(r.Value.Result.Items);
        _loadingMore = false;
    }

    private async Task OnSignalR(State.BudgetHubEvent e)
    {
        if (e.BudgetId != BudgetState.ActiveBudgetId) return;
        await LoadAsync(true); await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleSearch()
    {
        _searchOpen = !_searchOpen;
        if (_searchOpen) await Task.Delay(80).ContinueWith(_ => _searchRef.FocusAsync());
    }

    private void CloseSearch() { _searchOpen = false; _searchText = ""; Filter.Update(q => { q.FilterByDescription = false; q.Description = null; }); }
    private void OnSearch() => Filter.Update(q => { q.FilterByDescription = !string.IsNullOrWhiteSpace(_searchText); q.Description = _searchText; });

    private static string ShortLabel(JournalEntryType t) => t switch
    {
        JournalEntryType.Transaction   => "Transakt.",
        JournalEntryType.Milersattning => "Milersättn.",
        JournalEntryType.Vab           => "VAB",
        JournalEntryType.ReceiptBatch  => "Kvitton",
        _ => t.ToString()
    };

    private static string DotCss(JournalEntryType t) => t switch
    {
        JournalEntryType.Transaction   => "dot-tx",
        JournalEntryType.Milersattning => "dot-mi",
        JournalEntryType.Vab           => "dot-vab",
        JournalEntryType.ReceiptBatch  => "dot-kvitto",
        _ => "dot-tx"
    };

    private static string AmountCss(JournalEntryDto e) =>
        e.EntryType == JournalEntryType.ReceiptBatch ? "" : e.Amount >= 0 ? "amount-pos" : "amount-neg";

    private static string FormatAmount(JournalEntryDto e) =>
        e.EntryType == JournalEntryType.ReceiptBatch
            ? $"{e.Amount:N0} kr"
            : (e.Amount >= 0 ? "+" : "") + $"{e.Amount:N0} kr";

    private static string StatusDot(string s) => s switch
    {
        "Inskickad" => "status-dot-warning",
        "Godkänd"   => "status-dot-success",
        "Avslagen"  => "status-dot-danger",
        "Utbetald"  => "status-dot-info",
        _ => ""
    };

    public void Dispose()
    {
        Filter.FilterChanged     -= OnFilterChanged;
        BudgetState.StateChanged -= OnStateChanged;
        SignalR.OnBudgetEvent    -= OnSignalR;
    }
}
